<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <title><%= post.title %> - NodeShare</title>
  <style>
    body { font-family: 'Malgun Gothic', '맑은 고딕', sans-serif; max-width: 700px; margin: 40px auto; background:#fff; color:#111; }
    h1   { color:#2a7a2a; }
    .body { background:#f5f5f5; padding:16px; border:1px solid #ddd; white-space:pre-wrap; }
    a    { color:#1a6aaa; }
  </style>
</head>
<body>
  <h1><%= post.title %></h1>
  <div class="body"><%= post.body %></div>
  <br>
  <a href="/">← 목록으로</a>
</body>
</html>
